{% for r in resources %}
module "{{ r.logical_name }}" {
  source   = "./modules/{{ r.module }}"
  name     = "{{ naming.prefix }}-{{ r.logical_name }}-{{ naming.env }}"
  location = var.location
  tags     = var.tags

  {% if r.module == "virtual_machine" %}
  admin_username = var.vm_admin_username
  admin_password = var.vm_admin_password
  {% endif %}
}
{% endfor %}